PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# PostgreSQL (Neon)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRES=1h
JWT_REFRESH_EXPIRES=7d

# Redis (ioredis — BullMQ, cache, rate limiting)
REDIS_URL=redis://localhost:6379

# Kafka (Upstash or local)
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=codearena
KAFKA_ENABLED=false

# Email (nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=CodeArena <noreply@yourdomain.com>

# Cohere AI
COHERE_API_KEY=your-cohere-api-key
COHERE_API_URL=https://api.cohere.ai/v2/chat
COHERE_MODEL=command-r-plus

# Admin API key (for problem upload via admin panel)
ADMIN_API_KEY=change-me-admin-secret-key

# Docker execution sandbox (optional — set false to run locally)
DOCKER_SANDBOX_IMAGE=codearena-sandbox:latest
EXECUTION_ENABLED=false

# Client (Next.js) — use 5000 for npm run dev, 5001 when using docker-compose backend
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000
