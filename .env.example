PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# PostgreSQL (Neon)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/codearena

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Redis (BullMQ, cache, rate limiting)
REDIS_URL=redis://localhost:6379

# Kafka (Upstash or local)
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=codearena
KAFKA_ENABLED=false

# Email (nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=CodeArena <noreply@codearena.dev>

# AI (OpenAI-compatible API)
AI_API_KEY=
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_MODEL=gpt-4o-mini

# Docker execution sandbox
DOCKER_SANDBOX_IMAGE=codearena-sandbox:latest
EXECUTION_ENABLED=false
